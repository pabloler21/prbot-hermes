# Variables de entorno del proyecto — SOLO nombres, sin valores.
# En el VPS, los valores reales van en ~/.hermes/.env con chmod 600.
# Este archivo se versiona; el .env real NUNCA se commitea.

# --- LLM (Fase 1) ---
# API key de OpenRouter. Modelo en uso: moonshotai/kimi-k2.6
OPENROUTER_API_KEY=

# --- Discord (Fase 1) ---
# Token del bot de Discord.
DISCORD_BOT_TOKEN=
# IDs de usuarios autorizados, separados por coma. Sin allow-all.
DISCORD_ALLOWED_USERS=

# --- GitHub (Fase 3) ---
# Personal Access Token scopeado: lectura de repos/PRs/issues + escritura de
# comentarios. Sin merge/push/force-push.
GITHUB_PAT=

# --- Redis / BullMQ (Fase 4) ---
# URL de conexión a Redis (bind local, con password).
REDIS_URL=
