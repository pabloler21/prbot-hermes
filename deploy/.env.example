# Variables de entorno del proyecto — SOLO nombres, sin valores.
# En el VPS, los valores reales van en ~/.hermes/.env con chmod 600.
# Este archivo se versiona; el .env real NUNCA se commitea.

# --- LLM (Fase 1) ---
# API key de OpenCode (suscripción Go). Modelo en uso: kimi-k2.7-code
OPENCODE_API_KEY=

# --- Discord (Fase 1) ---
# Token del bot de Discord (Hermes / gateway).
DISCORD_BOT_TOKEN=
# IDs de usuarios autorizados, separados por coma. Sin allow-all.
# (También son los autorizados a aprobar/rechazar en el bot de aprobación.)
DISCORD_ALLOWED_USERS=

# --- Discord approval bot (Fase 3b) ---
# Token del SEGUNDO bot de Discord ("APPROVAL_BOT"), dueño de los botones ✅/❌.
# Es una app distinta de Hermes (no forkeamos Hermes, así que los botones los
# maneja un bot propio).
DISCORD_APPROVAL_BOT_TOKEN=
# ID del canal donde el bot postea los pedidos de aprobación.
DISCORD_APPROVAL_CHANNEL_ID=

# --- GitHub (Fase 3) ---
# Personal Access Token scopeado: lectura de repos/PRs/issues + escritura de
# comentarios. Sin merge/push/force-push.
GITHUB_PAT=

# --- Redis / arq (Fase 3b) ---
# URL de conexión a Redis (bind local, con password). Formato:
# redis://:<password>@127.0.0.1:6379
REDIS_URL=
